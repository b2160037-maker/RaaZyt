# ---- RAAZ FILES local secrets (.env) ----
# Copy this file to ".env" and paste your keys. Lines starting with # are ignored.
# Only GEMINI + PEXELS + YouTube are needed to start; the rest are free backups.

GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
HF_TOKEN=
PEXELS_API_KEY=
PIXABAY_API_KEY=
STABLEHORDE_KEY=0000000000

# Email (optional -- daily "topic" + "done" mails). Use a Gmail App Password.
GMAIL_USER=
GMAIL_APP_PASSWORD=
OWNER_EMAIL=

# Optional overrides
CHANNEL_NAME=RAAZ FILES
TTS_VOICE=hi-IN-SwaraNeural
TTS_RATE=+20%
YT_PRIVACY=public

# --- YouTube auth ---
# EASIEST on Windows: just keep the two files  client_secret.json  and  token.json
# in this project folder (run get_token.py once to make token.json). Then you can
# leave the two lines below EMPTY -- config.py reads the files automatically.
# (Or paste the JSON as single-line values if you prefer.)
YT_CLIENT_SECRET_JSON=
YT_TOKEN_JSON=
